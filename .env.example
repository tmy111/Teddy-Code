# Legacy fallback only. Prefer .teddycode.toml for provider profiles.

# DeepSeek uses its Anthropic-compatible endpoint by default.
TEDDYCODE_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
TEDDYCODE_DEEPSEEK_API_KEY=
TEDDYCODE_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional shared right.codes key. Used by OpenAI-compatible and
# Anthropic-compatible profiles when provider-specific keys are empty.
TEDDYCODE_RIGHT_CODES_API_KEY=

# OpenAI-compatible endpoint.
TEDDYCODE_OPENAI_API_BASE=https://www.right.codes/codex/v1
TEDDYCODE_OPENAI_API_KEY=
TEDDYCODE_OPENAI_MODEL=gpt-5.4

# Anthropic-compatible endpoint.
TEDDYCODE_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
TEDDYCODE_ANTHROPIC_API_KEY=
TEDDYCODE_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
TEDDYCODE_SECRET_ENV_NAMES=
